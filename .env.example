DISCORD_TOKEN=        # Discord Botトークン
CLIENT_ID=            # Application ID
GUILD_ID=             # テスト用サーバーID (省略でグローバル登録)
VOICEVOX_URL=http://localhost:50021
DEFAULT_STYLE_ID=3    # 3=ノーマル
WHISPER_MODEL=base    # tiny/base/small/medium/large
PYTHON_PATH=python    # Pythonの実行パス (venv使用時は絶対パス)
TEMP_DIR=./tmp
SILENCE_DURATION=800  # 無音検知タイムアウト(ms)
WHISPER_LANGUAGE=ja
